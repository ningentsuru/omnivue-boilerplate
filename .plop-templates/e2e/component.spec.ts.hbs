import { test, expect } from '@playwright/test'
import { ROUTES } from '../src/constants/index.js'

test('visits the {{kebabCase name}} url', async ({ page }) => {
  await page.goto(ROUTES.{{constantCase name}}.path)

  const container = page.getByTestId('{{kebabCase name}}')

  await expect(container).toBeAttached()
})
