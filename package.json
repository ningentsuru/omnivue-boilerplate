{
  "name": "omnivue-boilerplate",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "author": {
    "name": "Ningen Tsuru",
    "email": "ja.sardido@outlook.com",
    "url": "https://github.com/ningentsuru"
  },
  "description": "A universal Vue 3 boilerplate with Vite, TypeScript, shadcn-vue, Capacitor, and Tauri",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ningentsuru/omnivue-boilerplate.git"
  },
  "keywords": [
    "boilerplate",
    "starter",
    "template",
    "vue",
    "vite",
    "typescript",
    "capacitor",
    "tauri",
    "shadcn-vue",
    "cross-platform"
  ],
  "bugs": {
    "url": "https://github.com/ningentsuru/omnivue-boilerplate/issues"
  },
  "homepage": "https://github.com/ningentsuru/omnivue-boilerplate#readme",
  "scripts": {
    "dev": "vite",
    "dev:android": "cross-env CAPACITOR_DEV=true pnpm build:android && pnpm dev",
    "dev:ios": "cross-env CAPACITOR_DEV=true pnpm build:ios && pnpm dev",
    "dev:desktop": "tauri dev",
    "build": "run-p type-check \"build-only {@}\" --",
    "build:android": "pnpm build && npx cap sync && npx cap open android",
    "build:ios": "pnpm build && npx cap sync && npx cap open ios",
    "build:desktop": "tauri build",
    "preview": "vite preview",
    "test": "run-s test:unit test:e2e",
    "test:unit": "vitest",
    "test:e2e": "playwright test",
    "build-only": "vite build",
    "type-check": "vue-tsc --build",
    "lint": "run-s \"lint:*\"",
    "lint:oxlint": "oxlint . --fix",
    "lint:eslint": "eslint . --fix --cache",
    "format": "prettier --write --experimental-cli src/",
    "storybook": "cross-env STORYBOOK=true storybook dev -p 6006",
    "build-storybook": "storybook build",
    "ui:add": "pnpx shadcn-vue@latest add",
    "make-component": "plop component"
  },
  "dependencies": {
    "@capacitor/android": "^8.4.1",
    "@capacitor/cli": "^8.4.1",
    "@capacitor/core": "^8.4.1",
    "@capacitor/ios": "^8.4.1",
    "@capacitor/status-bar": "^8.0.2",
    "@lucide/vue": "^1.21.0",
    "@tailwindcss/vite": "^4.3.1",
    "@vee-validate/zod": "^4.15.1",
    "@vueuse/core": "^14.3.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "github-markdown-css": "^5.9.0",
    "markdown-it": "^14.2.0",
    "pinia": "^3.0.4",
    "reka-ui": "^2.10.1",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.1",
    "vee-validate": "^4.15.1",
    "vue": "^3.5.39",
    "vue-router": "^5.1.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^5.2.1",
    "@playwright/test": "^1.61.1",
    "@storybook/addon-a11y": "^10.4.6",
    "@storybook/addon-docs": "^10.4.6",
    "@storybook/addon-onboarding": "^10.4.6",
    "@storybook/addon-vitest": "^10.4.6",
    "@storybook/vue3-vite": "^10.4.6",
    "@tauri-apps/cli": "^2.11.4",
    "@tsconfig/node24": "^24.0.4",
    "@types/jsdom": "^28.0.3",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^26.0.1",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vitejs/plugin-vue-jsx": "^5.1.6",
    "@vitest/browser-playwright": "4.1.9",
    "@vitest/coverage-v8": "4.1.9",
    "@vitest/eslint-plugin": "^1.6.20",
    "@vue/eslint-config-typescript": "^14.9.0",
    "@vue/test-utils": "^2.4.11",
    "@vue/tsconfig": "^0.9.1",
    "cross-env": "^10.1.0",
    "dotenv": "^17.4.2",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-oxlint": "~1.71.0",
    "eslint-plugin-playwright": "^2.10.4",
    "eslint-plugin-storybook": "^10.4.6",
    "eslint-plugin-vue": "~10.9.2",
    "jsdom": "^29.1.1",
    "npm-run-all": "^4.1.5",
    "oxlint": "~1.71.0",
    "plop": "^4.0.5",
    "prettier": "3.9.1",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "storybook": "^10.4.6",
    "storybook-vue3-router": "^7.0.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "~6.0.3",
    "unplugin-auto-import": "^21.0.0",
    "unplugin-vue-components": "^32.1.0",
    "vite": "^8.1.0",
    "vite-plugin-vue-devtools": "^8.1.5",
    "vitest": "^4.1.9",
    "vue-eslint-parser": "^10.4.1",
    "vue-tsc": "^3.3.5"
  },
  "engines": {
    "node": "^22.18.0 || >=24.12.0"
  }
}
